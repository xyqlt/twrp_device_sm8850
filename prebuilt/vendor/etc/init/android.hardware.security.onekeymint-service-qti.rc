# Started by annibale-nxp-gate after QSEE/Mink/NXP Weaver are stable.

service vendor.keymint /vendor/bin/hw/android.hardware.security.onekeymint-service-qti
    class early_hal
    user root
    group root drmrpc
    setenv LD_LIBRARY_PATH /vendor/lib64:/vendor/lib64/hw:/system/lib64:/sbin:/odm/lib64
    disabled
    seclabel u:r:recovery:s0
