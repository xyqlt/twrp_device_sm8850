# Started by annibale-nxp-gate after KeyMint is stable.

service vendor.secretkeeper /vendor/bin/hw/android.hardware.security.secretkeeper-service-qti
    class hal
    user root
    group drmrpc
    setenv LD_LIBRARY_PATH /vendor/lib64:/vendor/lib64/hw:/system/lib64:/sbin:/odm/lib64
    disabled
    seclabel u:r:recovery:s0
