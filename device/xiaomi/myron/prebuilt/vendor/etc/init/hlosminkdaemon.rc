# Create the directories used by qwes
on post-fs-data
    mkdir /data/vendor/qwes 0755 system system

# Start daemon on early-init
on early-boot
    start vendor.minkdaemon

# Used 'disabled' flag, so daemon won't be started until explicit start
service vendor.minkdaemon /vendor/bin/hlosminkdaemon
    class late_start
    user system
    group system oem_2912 wakelock
    capabilities WAKE_ALARM BLOCK_SUSPEND
    disabled
    socket ssgtzd stream 0660 system oem_2912
    socket hlos_mink_opener stream 0660 system system
    setenv LD_LIBRARY_PATH /vendor/lib64:/vendor/lib64/hw:/odm/lib64:/system/lib64:/sbin
    seclabel u:r:recovery:s0
